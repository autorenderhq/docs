{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AutoRender Docs",
  "colors": {
    "primary": "#0F172A",
    "light": "#4F46E5",
    "dark": "#020617"
  },
  "favicon": "/favicon.ico",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Home",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/quickstart",
              {
                "group": "Integrations",
                "pages": [
                  "integrations/web-server",
                  "integrations/shopify",
                  {
                    "group": "External storage",
                    "pages": [
                      "integrations/external-storage/overview",
                      "integrations/external-storage/s3",
                      "integrations/external-storage/azure",
                      "integrations/external-storage/gcp"
                    ]
                  }
                ]
              },
              {
                "group": "SDKs",
                "pages": [
                  "getting-started/sdks/overview",
                  "getting-started/sdks/javascript",
                  "getting-started/sdks/react",
                  "getting-started/sdks/vue",
                  "getting-started/sdks/svelte",
                  "getting-started/sdks/nextjs",
                  "getting-started/sdks/angular"
                ]
              }
            ]
          },
          {
            "group": "IMAGE & VIDEO API",
            "pages": [
              "essentials/transformations",
              {
                "group": "Image",
                "pages": [
                  "essentials/overview",
                  "essentials/automatic",
                  "essentials/resize",
                  "essentials/crop",
                  "essentials/zoom",
                  "essentials/rotate",
                  "essentials/flip",
                  "essentials/effects",
                  "essentials/text-layers",
                  "essentials/image-layers",
                  "essentials/recipes"
                ]
              },
              {
                "group": "Video",
                "pages": [
                  "essentials/video/overview",
                  "essentials/video/thumbnail",
                  "essentials/video/resize",
                  "essentials/video/trim",
                  "essentials/video/rotate",
                  "essentials/video/flip",
                  "essentials/video/gif"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "GET STARTED",
            "pages": [
              "api-reference/authentication"
            ]
          },
          {
            "group": "ENDPOINTS",
            "pages": [
              {
                "group": "Upload",
                "pages": [
                  "api-reference/direct-upload",
                  {
                    "group": "Multipart Upload",
                    "pages": [
                      "api-reference/multipart-start",
                      "api-reference/multipart-upload-parts",
                      "api-reference/multipart-complete"
                    ]
                  }
                ]
              },
              {
                "group": "File Management",
                "pages": [
                  "api-reference/list-files",
                  "api-reference/get-file-details",
                  "api-reference/rename-file",
                  "api-reference/delete-file"
                ]
              },
              {
                "group": "Folder Management",
                "pages": [
                  "api-reference/list-folders",
                  "api-reference/create-folder",
                  "api-reference/rename-folder",
                  "api-reference/delete-folder"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "MCP Server",
        "groups": [
          {
            "group": "Documentation",
            "pages": [
              "mcp-server/overview"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Open Dashboard",
      "href": "https://app.autorender.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "fonts": {
    "heading": {
      "family": "Geist",
      "source": "https://unpkg.com/geist@1.5.1/dist/fonts/geist-sans/Geist-Bold.woff2",
      "format": "woff2",
      "weight": 800
    },
    "body": {
      "family": "Geist",
      "source": "https://unpkg.com/geist@1.5.1/dist/fonts/geist-sans/Geist-Regular.woff2",
      "format": "woff2",
      "weight": 400
    }
  }
}