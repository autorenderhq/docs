{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AutoRender Docs",
  "colors": {
    "primary": "#0F172A",
    "light": "#4F46E5",
    "dark": "#020617"
  },
  "favicon": "/favicon.ico",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Start",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "getting-started/quickstart",
              "getting-started/first-image",
              "getting-started/upload-assets",
              "sdk/overview"
            ]
          }
        ]
      },
      {
        "tab": "Transform",
        "groups": [
          {
            "group": "Media Transformations",
            "pages": [
              "essentials/transformations",
              "essentials/overview",
              "essentials/automatic",
              "essentials/resize",
              "essentials/crop",
              "essentials/zoom",
              "essentials/rotate",
              "essentials/flip",
              "essentials/border-radius",
              "essentials/effects",
              "essentials/effects/brightness",
              "essentials/effects/contrast",
              "essentials/effects/saturation",
              "essentials/effects/exposure",
              "essentials/effects/sharpen",
              "essentials/effects/grayscale",
              "essentials/layers",
              "essentials/recipes",
              "essentials/video/overview",
              "essentials/video/thumbnail",
              "essentials/video/resize",
              "essentials/video/pad-resize",
              "essentials/video/flip",
              "essentials/video/gif",
              "essentials/video/trim",
              "essentials/video/aspect-ratio",
              "essentials/video/rotate"
            ]
          }
        ]
      },
      {
        "tab": "SDKs",
        "groups": [
          {
            "group": "By Feature",
            "pages": [
              "sdk/overview",
              "sdk/view-sdk",
              "sdk/upload-sdk"
            ]
          },
          {
            "group": "By Framework",
            "pages": [
              "sdk/frameworks/react",
              "sdk/frameworks/nextjs",
              "sdk/frameworks/angular",
              "sdk/frameworks/svelte",
              "sdk/frameworks/vue"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Upload",
            "pages": [
              "api-reference/direct-upload",
              "api-reference/remote-upload",
              "api-reference/multipart-start",
              "api-reference/multipart-upload-parts",
              "api-reference/multipart-complete"
            ]
          },
          {
            "group": "Files & Folders",
            "pages": [
              "api-reference/list-files",
              "api-reference/get-file-details",
              "api-reference/rename-file",
              "api-reference/delete-file",
              "api-reference/list-folders",
              "api-reference/create-folder",
              "api-reference/rename-folder",
              "api-reference/delete-folder"
            ]
          }
        ]
      },
      {
        "tab": "Use Cases",
        "groups": [
          {
            "group": "Quick Commerce",
            "pages": [
              "blog/quick-commerce/getting-started",
              "blog/quick-commerce/best-practices",
              "blog/quick-commerce/examples",
              "blog/quick-commerce/performance",
              "blog/quick-commerce/advanced"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Open Dashboard",
      "href": "https://app.autorender.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "fonts": {
    "heading": {
      "family": "Geist",
      "source": "https://unpkg.com/geist@1.5.1/dist/fonts/geist-sans/Geist-Regular.woff2",
      "format": "woff2",
      "weight": 600
    },
    "body": {
      "family": "Geist",
      "source": "https://unpkg.com/geist@1.5.1/dist/fonts/geist-sans/Geist-Regular.woff2",
      "format": "woff2",
      "weight": 400
    }
  }
}