    "/api/v1/multipart/parts": {
      "put": {
        "operationId": "uploadMultipartPart",
        "summary": "Upload part",
        "description": "Upload **one part** of the file as raw bytes (`Content-Type: application/octet-stream`).\n\n**Request URL:** Use the **full presigned URL** from `parts[i]` returned by `POST /api/v1/multipart/start` (typically object storage). It is not this documentation path—the generated sample URL is only a template; substitute your real `parts[i]` value, including path and query flags.\n\n**Authentication:** Do **not** send your AutoRender `Authorization` header. Signatures are already in the presigned URL.\n\nUpload every index in `parts` in order, then call `POST /api/v1/multipart/complete`.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": {
                "$ref": "#/components/schemas/MultipartPartBinary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Part stored successfully (storage may return an empty body)",
            "headers": {
              "ETag": {
                "description": "Part entity tag when supported by storage",
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Upload rejected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
