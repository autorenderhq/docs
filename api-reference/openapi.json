{
  "openapi": "3.1.0",
  "info": {
    "title": "AutoRender API",
    "description": "AutoRender upload, file, folder, and multipart APIs",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://upload.autorender.io"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    },
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/api/v1/uploads": {
      "post": {
        "operationId": "uploadFile",
        "summary": "Direct upload",
        "description": "Upload a file to your AutoRender workspace with optional transformations, tags, and folder organization",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyAuth": []
          }
        ],
        "requestBody": {
          "description": "File upload with optional settings",
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file", "file_name"],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "The file to upload (binary data)"
                  },
                  "file_name": {
                    "type": "string",
                    "description": "File name for the uploaded file (e.g., my-image.jpg)"
                  },
                  "folder": {
                    "type": "string",
                    "description": "Folder path where the file will be stored (e.g., uploads/my-folder)"
                  },
                  "tags": {
                    "type": "string",
                    "description": "Comma-separated tags (e.g., tag1,tag2,tag3)"
                  },
                  "transform": {
                    "type": "string",
                    "description": "Image transformation string (e.g., w_800,h_600,q_90)"
                  },
                  "metadata": {
                    "type": "string",
                    "description": "JSON string for custom metadata (e.g., {\"key\": \"value\"})"
                  },
                  "custom_id": {
                    "type": "string",
                    "description": "Custom identifier for the file"
                  },
                  "random_prefix": {
                    "type": "string",
                    "description": "Set to \"true\" to add a random suffix to filename"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadError"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadError"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/files": {
      "get": {
        "operationId": "listFiles",
        "summary": "List files",
        "description": "Paginated list of files in the workspace. Filter by folder, sort by field and order, and page through results.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number (1-based)",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Items per page",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "sort_field",
            "in": "query",
            "description": "Field to sort by",
            "schema": {
              "type": "string",
              "enum": ["file_size", "name", "created_at", "updated_at"]
            }
          },
          {
            "name": "sort_order",
            "in": "query",
            "description": "Sort direction",
            "schema": {
              "type": "string",
              "enum": ["asc", "desc"],
              "default": "desc"
            }
          },
          {
            "name": "folder_no",
            "in": "query",
            "description": "Restrict results to files in this folder (folder number)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name",
            "in": "query",
            "description": "Filter by filename (partial match, if supported)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "path",
            "in": "query",
            "description": "Filter by path prefix (if supported)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tags",
            "in": "query",
            "description": "Comma-separated tags (if supported)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of files and pagination meta",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileListResponse"
                },
                "example": {
                  "files": [
                    {
                      "file_no": "2353377462",
                      "name": "ar-juice.jpg",
                      "thumbanil": "https://dev.autorender.io/FWA7PWC7LZ/h_320,w_320,c_center/ar-juice.jpg",
                      "url": "https://dev.autorender.io/FWA7PWC7LZ/ar-juice.jpg",
                      "file_size": 1278975,
                      "format": "jpg",
                      "width": 3788,
                      "height": 5869,
                      "created_at": "2026-03-27T14:58:53.795Z",
                      "workspace_no": "FWA7PWC7LZ",
                      "path": "ar-juice.jpg",
                      "extension": "image"
                    }
                  ],
                  "meta": {
                    "page": 1,
                    "limit": 20,
                    "total": 2,
                    "hasNext": false,
                    "hasPrev": false
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadError"
                }
              }
            }
          }
        }
      }
    },
