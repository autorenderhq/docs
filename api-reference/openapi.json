    "/api/v1/multipart/start": {
      "post": {
        "operationId": "startMultipartUpload",
        "summary": "Start multipart upload",
        "description": "Creates a multipart session and returns part size and presigned PUT URLs for each part. Use for large files uploaded in chunks.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MultipartStartRequest"
              },
              "example": {
                "file_name": "big-video.mp4",
                "size": 73400320,
                "format": "video/mp4",
                "folder": "uploads/videos",
                "tags": ["campaign", "raw"],
                "metadata": { "source": "mobile-app" },
                "custom_id": "vid_001",
                "random_prefix": false,
                "ttl_seconds": 3600
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session created; presigned URLs returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MultipartStartResponse"
                },
                "example": {
                  "session_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                  "part_size": 10485760,
                  "parts": [
                    "https://storage.example.com/presigned-part-1?X-Amz-Signature=abc",
                    "https://storage.example.com/presigned-part-2?X-Amz-Signature=def"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request - validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadError"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadError"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadError"
                }
              }
            }
          }
        }
      }
    },
