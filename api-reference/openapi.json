      "delete": {
        "operationId": "deleteFile",
        "summary": "Delete file",
        "description": "Permanently delete a file. No request body is required.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "fileNo",
            "in": "path",
            "required": true,
            "description": "File number to delete",
            "schema": {
              "type": "string",
              "example": "2338056701"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteFileResponse"
                },
                "example": {
                  "message": "file deleted successfully"
                }
              }
            }
          },
          "404": {
            "description": "File not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadError"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/files/{fileNo}/rename": {
      "patch": {
        "operationId": "renameFile",
        "summary": "Rename file",
        "description": "Rename a file. The API may preserve or normalize the file extension (e.g. `demo` → `demo.png`).",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "fileNo",
            "in": "path",
            "required": true,
            "description": "File number",
            "schema": {
              "type": "string",
              "example": "2338045312"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RenameFileRequest"
              },
              "example": {
                "name": "demo"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File renamed; returns updated file record",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileRenameResult"
                }
              }
            }
          },
          "404": {
            "description": "File not found or access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileNotFoundError"
                },
                "example": {
                  "error": "File with ID File not found or access denied not found",
                  "code": "FILE_NOT_FOUND"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadError"
                }
              }
            }
          }
        }
      }
    },
